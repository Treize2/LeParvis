# Copy this to /home/<SCALEWAY_USER>/LeParvis/.env on the instance.
# The deploy workflow refuses to run if .env is missing.

# Public domain that the taskrabbit Caddy will route to LeParvis.
DOMAIN_NAME=leparvis.dauchez.me

# Scaleway Container Registry namespace (must match the GitHub var SCW_NAMESPACE).
SCW_NAMESPACE=treize

# Default images used when running `docker compose up` manually on the box.
# CI overrides these with sha-pinned tags during deploy.
API_IMAGE=rg.fr-par.scw.cloud/treize/leparvis-api:latest
WEB_IMAGE=rg.fr-par.scw.cloud/treize/leparvis-web:latest

# The shared docker network used by taskrabbit's Caddy. Defaults to `web`.
# `docker network create web` once if it doesn't exist yet.
SHARED_NETWORK=web

# Identification used by the scraper (must contain a real contact).
SCRAPER_USER_AGENT=LeParvisBot/0.1 (+contact@dauchez.me)

# Only used by the optional `edge` profile (standalone Caddy). Leave as-is
# if taskrabbit's Caddy is doing the TLS termination.
ACME_EMAIL=admin@dauchez.me
